# Переименуй этот файл в .env и подставь свои данные
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Serper.dev API Key (для поиска BD/Founder контактов)
# Бесплатный план: 2500 запросов/мес
# Получить: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# CoinGecko API Key (опционально, для снятия rate-limit)
# CG_API_KEY=your_coingecko_api_key_here

# Resend API Key (для рассылки email)
# Получить: https://resend.com
RESEND_API_KEY=your_resend_api_key_here

# Gemini API Key (для AI-персонализации писем)
# Получить: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Token (для запуска workflow из dashboard)
# Получить: https://github.com/settings/tokens
# Права: repo, workflow
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=iaqool/tothemoon

# API Secret (используется для защиты Vercel API endpoints)
# Одинаковый на Vercel и в dashboard/.env (VITE_API_SECRET)
API_SECRET=your_random_secret_here

# Resend Webhook Secret (для верификации inbound webhook)
RESEND_WEBHOOK_SECRET=your_resend_webhook_secret_here

# ─── Telegram Parser ────────────────────────────────────────────────
# Telegram API credentials (from https://my.telegram.org)
TELEGRAM_API_ID=your_telegram_api_id_here
TELEGRAM_API_HASH=your_telegram_api_hash_here
# Session string (generated via: python tg_auth.py)
TELEGRAM_SESSION=your_session_string_here
# Comma-separated channel usernames to parse
# TG_CHANNELS=crypto_news,ton_news,solana_updates
# TG_PARSE_LIMIT=50

# ─── Outreach Configuration ────────────────────────────────────────
# OUTREACH_DAILY_LIMIT=50          # Max cold emails per day (default: 50)
# OUTREACH_FOLLOWUP_LIMIT=30       # Max follow-ups per day (default: 30)
# OUTREACH_START_DATE=2025-05-01   # Warm-up start date (YYYY-MM-DD); omit to disable warm-up
# FOLLOWUP_1_DAYS=4                # Days after Stage 1 before Follow-up 1
# FOLLOWUP_2_DAYS=10               # Days after Follow-up 1 before Follow-up 2
# EMAIL_SEND_RETRIES=3             # Retry attempts for failed sends
